# Always use LF line endings in the repo (Linux/macOS/Render compatible)
* text=auto eol=lf

# Explicitly force LF for these types
*.py    text eol=lf
*.md    text eol=lf
*.yaml  text eol=lf
*.yml   text eol=lf
*.txt   text eol=lf
*.toml  text eol=lf
*.cfg   text eol=lf

# Treat these as binary — no line ending conversion
*.pdf   binary
*.png   binary
*.jpg   binary
